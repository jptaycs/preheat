# Database
DATABASE_URL=postgresql://preheat:preheat@localhost:5432/preheat_dev

# Auth
JWT_SECRET=change_me_to_a_long_random_secret_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Server
PORT=4000
HOST=0.0.0.0
NODE_ENV=development

# Push Notifications (Expo)
EXPO_PUSH_TOKEN_URL=https://exp.host/--/api/v2/push/send

# Error Monitoring (Sentry)
# Get your DSN from https://sentry.io/settings/projects/ → Client Keys
SENTRY_DSN=

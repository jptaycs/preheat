{
  "name": "@preheat/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "node --import tsx/esm src/db/migrate.ts",
    "db:seed": "node --import tsx/esm src/db/seed.ts",
    "db:seed:screenshots": "node --import tsx/esm src/db/seed-screenshots.ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^3.1.0",
    "@fastify/websocket": "^10.0.1",
    "@preheat/shared": "workspace:*",
    "@sentry/node": "^10.53.1",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.5",
    "fastify": "^4.27.0",
    "pg": "^8.11.5",
    "zod": "^3.23.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^20.12.7",
    "@types/pg": "^8.11.5",
    "tsx": "^4.8.2",
    "typescript": "^5.4.5",
    "vitest": "^1.5.2"
  }
}

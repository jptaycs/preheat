{
  "expo": {
    "name": "AeroFluxPro",
    "slug": "preheat",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0C0E14"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.preheat.app",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Use Face ID to sign in to AeroFluxPro",
        "UIBackgroundModes": ["remote-notification"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0C0E14"
      },
      "package": "com.preheat.app",
      "permissions": ["android.permission.USE_BIOMETRIC", "android.permission.USE_FINGERPRINT"]
    },
    "newArchEnabled": true,
    "scheme": "preheat",
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Use Face ID to sign in to AeroFluxPro"
        }
      ],
      "expo-asset",
      "expo-notifications",
      "@sentry/react-native/expo"
    ],
    "hooks": {
      "postPublish": [
        {
          "file": "sentry-expo/upload-sourcemaps",
          "config": {
            "organization": "preheat",
            "project": "preheat-mobile"
          }
        }
      ]
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "121bde1f-6f83-4358-b729-88344f883166"
      }
    },
    "owner": "jptaycs"
  }
}
